<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        xmlns:ctrl="clr-namespace:WpfApp1.Controls"
        mc:Ignorable="d"
        Title="USB Sensor &amp; Control Bridge" Height="720" Width="1080"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI" Foreground="{StaticResource TextBrush}">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============================ TOPBAR ============================ -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="USB Sensor &amp; Control Bridge"
                               FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="STM32G431 &#8596; PC  &#8226;  CDC Virtual COM  &#8226;  NMEA-Frames mit Checksum"
                               Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusLed" Width="13" Height="13" Margin="0,0,8,0"
                             Fill="{StaticResource AccentRed}"/>
                    <TextBlock x:Name="StatusText" Text="getrennt" VerticalAlignment="Center"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,16,0" FontSize="13"/>
                    <ComboBox x:Name="PortCombo" Width="120" VerticalAlignment="Center"/>
                    <Button Content="&#x21bb;" ToolTip="Ports neu suchen"
                            Style="{StaticResource FlatButton}" Margin="6,0,0,0"
                            Background="{StaticResource CardBorder}" Click="OnRefreshPorts"/>
                    <Button x:Name="ConnectBtn" Content="Verbinden" Width="110"
                            Style="{StaticResource FlatButton}" Margin="8,0,0,0"
                            Click="OnConnectClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================ MAIN ============================ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="MESSWERTE VOM BOARD" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,12"/>

                    <StackPanel x:Name="ValueList"/>

                    <Separator Margin="0,12" Background="{StaticResource CardBorder}"/>

                    <TextBlock Text="FRAME-STATISTIK" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="gueltig" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                            <TextBlock x:Name="FramesOk" Text="0" FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource AccentGreen}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="CRC-Fehler" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                            <TextBlock x:Name="FramesErr" Text="0" FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource AccentRed}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="TEMPERATURVERLAUF" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
                    <ctrl:TrendChart x:Name="Chart" Grid.Row="1"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ============================ CONTROLS ============================ -->
        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,7,0">
                <StackPanel>
                    <TextBlock Text="IO-STEUERUNG (LT1377)" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="EIN" Width="80" Style="{StaticResource FlatButton}"
                                Background="{StaticResource AccentGreen}" Click="OnLt1377On"/>
                        <Button Content="AUS" Width="80" Style="{StaticResource FlatButton}"
                                Background="{StaticResource AccentRed}" Margin="8,0,0,0" Click="OnLt1377Off"/>
                        <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                            <Ellipse x:Name="Lt1377Led" Width="13" Height="13" Margin="0,0,8,0"
                                     Fill="{StaticResource TextMuted}"/>
                            <TextBlock x:Name="Lt1377State" Text="unbekannt"
                                       Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="Schaltbefehl wird vom Board mit $ACK bestaetigt"
                               Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="7,0,7,0">
                <StackPanel>
                    <TextBlock Text="CSV-LOGGER" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="LogBtn" Content="Logging starten" Width="140"
                                Style="{StaticResource FlatButton}" Click="OnToggleLogging"/>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="LogCount" Text="0 Zeilen"
                                       Foreground="{StaticResource TextBrush}" FontSize="13"/>
                            <TextBlock x:Name="LogPath" Text="keine Datei"
                                       Foreground="{StaticResource TextMuted}" FontSize="11"
                                       TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}" Margin="7,0,0,0">
                <StackPanel>
                    <TextBlock Text="PC &#8594; BOARD (Anzeige auf Display)" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,10"/>
                    <CheckBox x:Name="SendPcChk" Content="Systemzeit + CPU automatisch senden"
                              Foreground="{StaticResource TextBrush}" IsChecked="True"
                              Checked="OnSendPcToggled" Unchecked="OnSendPcToggled"/>
                    <TextBlock x:Name="PcPreview" Text="-" Foreground="{StaticResource AccentCyan}"
                               FontFamily="Consolas" FontSize="12" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
